model OutreachSequence {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Basic Info
  name            String
  description     String?
  
  // Sequence Type
  sequenceType    String   @default("email") // email, linkedin, mixed, sms, whatsapp
  status          String   @default("draft") // draft, active, paused, archived
  
  // Targeting
  targetCriteria  Json?    // { tags: [], leadScoreMin: 50, industries: [], etc }
  
  // Schedule Settings
  scheduleSettings Json    @default("{}")
  // {
  //   timezone: "America/New_York",
  //   businessHours: { start: "09:00", end: "17:00" },
  //   daysOfWeek: ["monday", "tuesday", "wednesday", "thursday", "friday"],
  //   skipHolidays: true,
  //   optimalSendTime: true
  // }
  
  // Performance
  totalEnrolled   Int      @default(0)
  totalCompleted  Int      @default(0)
  totalConverted  Int      @default(0)
  conversionRate  Float    @default(0)
  
  // A/B Testing
  isABTest        Boolean  @default(false)
  abTestConfig    Json?    // { variantA: { steps: [] }, variantB: { steps: [] } }
  
  // Exit Conditions
  exitConditions  Json?    // [{ type: "replied", action: "exit" }, { type: "booked_meeting", action: "exit" }]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  steps           OutreachStep[]
  enrollments     SequenceEnrollment[]
  
  @@index([organizationId])
  @@index([status])
  @@map("outreach_sequences")
}

model OutreachStep {
  id              String   @id @default(cuid())
  sequenceId      String
  sequence        OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  
  // Step Info
  name            String
  stepNumber      Int
  
  // Channel
  channel         String   @default("email") // email, linkedin, phone, sms, whatsapp, task
  
  // Content
  templateId      String?
  template        MessageTemplate? @relation(fields: [templateId], references: [id])
  
  // Custom content (if no template)
  subject         String?
  body            String?  @db.Text
  
  // AI Generation
  useAI           Boolean  @default(false)
  aiPrompt        String?  @db.Text
  
  // Timing
  delayDays       Int      @default(1)
  delayHours      Int      @default(0)
  sendTime        String?  // "09:00" format
  
  // Conditions
  condition       Json?    // { type: "opened_previous", negate: false }
  
  // A/B Testing
  variant         String?  // "A" or "B"
  
  // Performance
  sentCount       Int      @default(0)
  openedCount     Int      @default(0)
  repliedCount    Int      @default(0)
  clickedCount    Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sequenceId])
  @@index([stepNumber])
  @@map("outreach_steps")
}

model MessageTemplate {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
