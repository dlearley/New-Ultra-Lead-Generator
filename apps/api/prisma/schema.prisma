  email_verification
  phone_verification
  intent_signal
}

enum CrmType {
  salesforce
  hubspot
  pipedrive
  zoho
  freshsales
  close
  other
}

enum FieldType {
  string
  number
  boolean
  date
  datetime
  email
  phone
  url
  select
  multiselect
  text
}

enum SyncStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum BuyingStage {
  unknown
  awareness
  consideration
  decision
  purchase
  churned
}

// ============================================================================
// BULK IMPORT
// ============================================================================

model BulkImportJob {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // File info
  fileName        String
  fileSize        Int
  
  // Status
  status          ImportJobStatus @default(pending)
  
  // Progress
  totalRows       Int @default(0)
  processedRows   Int @default(0)
  validRows       Int @default(0)
  invalidRows     Int @default(0)
  createdRecords  Int @default(0)
  updatedRecords  Int @default(0)
  skippedRows     Int @default(0)
  
  // Configuration
  config          Json
  
  // Errors
  errors          Json @default("[]")
  
  // Timestamps
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("bulk_import_jobs")
}

enum ImportJobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

// Legacy model - keeping for backwards compatibility
model BusinessLead {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  email          String
  firstName      String?
  lastName       String?
  phone          String?
  company        String?
  jobTitle       String?
  source         String?
  status         LeadStatus    @default(NEW)
  customFields   Json?
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  syncJobs       SyncJob[]

  @@unique([organizationId, email])
  @@map("business_leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}
// ============================================================================
// LEAD CAPTURE MODULE (Phase 1)
// ============================================================================

model LeadForm {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  // Form Configuration
  formType        String   @default("inline")
  status          String   @default("draft")
  
  // Design & Template
  design          Json     @default("{}")
  template        String?
  
  // Form Fields
  fields          Json     @default("[]")
  
  // Display Behavior
  triggerConfig   Json     @default("{}")
  displayRules    Json     @default("{}")
  
  // Post-Submission
  thankYouMessage String?
  redirectUrl     String?
  sendEmailConfirmation Boolean @default(false)
  
  // Lead magnet
  leadMagnetId    String?
  leadMagnet      LeadMagnet? @relation(fields: [leadMagnetId], references: [id])
  
  // Tracking
  views           Int      @default(0)
  submissions     Int      @default(0)
  conversions     Int      @default(0)
  conversionRate  Float    @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  formSubmissions FormSubmission[]
  conversions     Conversion[]

  @@index([organizationId])
  @@index([status])
  @@map("lead_forms")
}

model FormSubmission {
  id          String   @id @default(cuid())
  formId      String
  form        LeadForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  organizationId String
  data        Json     @default("{}")
  
  visitorId   String?
  visitor     WebsiteVisitor? @relation(fields: [visitorId], references: [id])
  
  ipAddress   String?
  userAgent   String?
  referrer    String?
  pageUrl     String?
  
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  
  contactId   String?
  converted   Boolean  @default(false)
  
  verified    Boolean  @default(false)
  verifiedAt  DateTime?
  
  submittedAt DateTime @default(now())

  @@index([formId])
  @@index([visitorId])
  @@index([organizationId])
  @@index([submittedAt])
  @@map("form_submissions")
}

model LandingPage {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  slug            String   @unique
  title           String
  description     String?
  content         Json     @default("[]")
  template        String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  status          String   @default("draft")
  publishedAt     DateTime?
  views           Int      @default(0)
  uniqueViews     Int      @default(0)
  conversions     Int      @default(0)
  conversionRate  Float    @default(0)
  formId          String?
  form            LeadForm? @relation(fields: [formId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([slug])
  @@map("landing_pages")
}

model WebsiteVisitor {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fingerprint     String
  sessionId       String
  ipAddress       String?
  country         String?
  city            String?
  region          String?
  timezone        String?
  companyName     String?
  companyDomain   String?
  companyIndustry String?
  companySize     String?
  companyRevenue  String?
  pageViews       Int      @default(0)
  sessionCount    Int      @default(1)
  firstVisitAt    DateTime @default(now())
  lastVisitAt     DateTime @updatedAt
  leadScore       Int      @default(0)
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])
  identifiedAt    DateTime?
  pageViewsList   VisitorPageView[]
  formSubmissions FormSubmission[]

  @@unique([organizationId, fingerprint])
  @@index([organizationId])
  @@index([fingerprint])
  @@index([contactId])
  @@index([companyDomain])
  @@map("website_visitors")
}

model VisitorPageView {
  id          String   @id @default(cuid())
  visitorId   String
  visitor     WebsiteVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  pageUrl     String
  pageTitle   String?
  referrer    String?
  timeOnPage  Int?
  scrollDepth Int?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  viewedAt    DateTime @default(now())

  @@index([visitorId])
  @@index([viewedAt])
  @@map("visitor_page_views")
}

model Chatbot {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  avatarUrl       String?
  primaryColor    String   @default("#3b82f6")
  position        String   @default("bottom-right")
  welcomeMessage  String   @default("Hi! How can I help you today?")
  welcomeDelay    Int      @default(2)
  flows           Json     @default("[]")
  autoOpen        Boolean  @default(false)
  autoOpenDelay   Int      @default(10)
  showOnMobile    Boolean  @default(true)
  workingHours    Json?
  status          String   @default("active")
  conversations   Int      @default(0)
  leadsCaptured   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("chatbots")
}

model LeadMagnet {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  type            String
  fileUrl         String?
  fileSize        Int?
  content         String?
  externalUrl     String?
  deliveryMethod  String   @default("immediate")
  emailTemplate   String?
  requireEmail    Boolean  @default(true)
  requirePhone    Boolean  @default(false)
  views           Int      @default(0)
  downloads       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  forms           LeadForm[]

  @@index([organizationId])
  @@index([type])
  @@map("lead_magnets")
}

model Conversion {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceType      String
  sourceId        String?
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])
  submissionId    String?
  submission      FormSubmission? @relation(fields: [submissionId], references: [id])
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  referrer        String?
  landingPage     String?
  visitorId       String?
  pageViews       Int      @default(0)
  timeToConvert   Int?
  estimatedValue  Float?
  convertedAt     DateTime @default(now())

  @@index([organizationId])
  @@index([contactId])
  @@index([sourceType])
  @@index([convertedAt])
  @@map("conversions")
}
// ============================================================================
// LAYER 7: AI-DRIVEN LEAD SCORING & QUALIFICATION
// ============================================================================

model LeadScoringModel {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  // Model Type
  modelType       String   @default("rule_based") // rule_based, ai_predictive, hybrid
  status          String   @default("active") // active, paused, archived
  
  // Scoring Rules
  rules           Json     @default("[]") // Array of scoring rules
  
  // Score Ranges
  hotThreshold    Int      @default(70)   // 70-100 = Hot
  warmThreshold   Int      @default(40)   // 40-69 = Warm
  // 0-39 = Cold (implicit)
  
  // Auto-qualification
  autoQualify     Boolean  @default(false)
  qualificationRules Json? @default("{}")
  
  // Routing
  routingRules    Json?    @default("{}") // Assignment rules by score
  
  // AI Model (if applicable)
  aiModelId       String?  // Reference to trained model
  aiWeights       Json?    // AI model weights
  
  // Performance
  accuracy        Float?   // Model accuracy score
  lastTrainedAt   DateTime?
  
  // Stats
  leadsScored     Int      @default(0)
  conversions     Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  scores          LeadScore[]

  @@index([organizationId])
  @@index([status])
  @@map("lead_scoring_models")
}

model LeadScore {
  id              String   @id @default(cuid())
  
  // Reference
  modelId         String
  model           LeadScoringModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  
  organizationId  String
  
  // Lead being scored
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // Scores
  totalScore      Int      @default(0)
  maxPossible     Int      @default(100)
  
  // Category
  category        String   @default("cold") // hot, warm, cold
  
  // Breakdown
  demographicScore Int     @default(0)
  behavioralScore  Int     @default(0)
  firmographicScore Int    @default(0)
  intentScore      Int     @default(0)
  engagementScore  Int     @default(0)
  
  // Rule contributions
  ruleBreakdown   Json     @default("[]") // Which rules contributed how much
  
  // AI Predictions
  conversionProbability Float? // 0-100 predicted conversion chance
  predictedValue   Float?      // Predicted deal value
  timeToClose      Int?        // Predicted days to close
  
  // Qualification
  qualified       Boolean  @default(false)
  qualificationData Json?  // Answers to qualification questions
  
  // Routing
  assignedToId    String?  // User ID assigned to
  assignedAt      DateTime?
  
  // History
  previousScore   Int?     // Last score before this one
  scoreChange     Int      @default(0)
  
  calculatedAt    DateTime @default(now())

  @@unique([modelId, contactId])
  @@index([organizationId])
  @@index([contactId])
  @@index([category])
  @@index([totalScore])
  @@index([calculatedAt])
  @@map("lead_scores")
}

model ScoringRule {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?  // Plain-English description
  
  // Rule Type
  ruleType        String   // demographic, behavioral, firmographic, intent, engagement, qualification
  
  // Condition
  condition       Json     // { field, operator, value }
  // Examples:
  // { field: "company.size", operator: "gte", value: 100 }
  // { field: "behavior.pagesVisited", operator: "contains", value: "/pricing" }
  // { field: "intent.signals", operator: "has", value: "pricing_view" }
  
  // Action
  action          Json     // { type: "add_points" | "set_flag", value: 20 }
  
  // Points
  points          Int      @default(0) // Can be negative for penalties
  
  // Cap
  maxPoints       Int?     // Maximum points this rule can award
  
  // Frequency
  frequency       String   @default("once") // once, daily, per_session, unlimited
  
  // Active
  isActive        Boolean  @default(true)
  priority        Int      @default(0) // Higher = evaluated first
  
  // Stats
  timesTriggered  Int      @default(0)
  totalPointsAwarded Int   @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([ruleType])
  @@index([isActive])
  @@map("scoring_rules")
}

model QualificationQuestion {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Question
  question        String
  description     String?
  
  // Type
  questionType    String   // single_choice, multiple_choice, text, number, boolean, scale
  
  // Options (for choice types)
  options         Json?    // [{ value, label, points, flag }]
  
  // Scoring
  isScoring       Boolean  @default(true) // Does this affect score?
  weight          Float    @default(1.0)  // Question weight in scoring
  
  // Qualification
  disqualifyIf    Json?    // Conditions that disqualify
  requiredForQualification Boolean @default(false)
  
  // Display
  displayCondition Json?   // When to show this question
  order           Int      @default(0)
  
  // Active
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
  @@map("qualification_questions")
}

model LeadQualification {
  id              String   @id @default(cuid())
  organizationId  String
  
  // Lead
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // Qualification
  isQualified     Boolean  @default(false)
  qualificationScore Int   @default(0)
  
  // Answers
  answers         Json     // { questionId: { answer, score, timestamp } }
  
  // BANT Criteria
  hasBudget       Boolean?
  hasAuthority    Boolean?
  hasNeed         Boolean?
  hasTimeline     Boolean?
  
  // Qualification Method
  method          String   // chatbot, form, manual, ai_inferred
  qualifiedById   String?  // User who qualified (if manual)
  
  // Disqualification
  isDisqualified  Boolean  @default(false)
  disqualificationReason String?
  
  qualifiedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([contactId])
  @@index([isQualified])
  @@map("lead_qualifications")
}

model ScoreHistory {
  id              String   @id @default(cuid())
  organizationId  String
  
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // Score snapshot
  score           Int
  category        String
  
  // What changed
  triggerType     String   // rule_triggered, behavior, time_decay, manual_adjustment
  triggerId       String?  // ID of rule or event
  
  // Change details
  previousScore   Int
  change          Int
  reason          String?
  
  // Snapshot
  ruleBreakdown   Json     // Score breakdown at this point
  
  recordedAt      DateTime @default(now())

  @@index([organizationId])
  @@index([contactId])
  @@index([recordedAt])
  @@map("score_history")
}

model SalesRouting {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  // Routing Rules
  rules           Json     // [{ condition, assignTo, priority }]
  
  // Assignment
  defaultAssigneeId String?
  roundRobinUsers String[] // For round-robin assignment
  
  // Criteria
  minScore        Int?     // Minimum score to trigger
  categories      String[] // hot, warm
  
  // Auto-assignment
  autoAssign      Boolean  @default(true)
  notifyAssignee  Boolean  @default(true)
  
  // Escalation
  escalationRules Json?    // Escalate if not contacted in X hours
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
  @@map("sales_routing")
}

model PredictiveModel {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  // Model Details
  modelType       String   // conversion_probability, deal_value, time_to_close
  algorithm       String   // logistic_regression, random_forest, neural_network
  
  // Training Data
  trainingDataSize Int
  trainedAt       DateTime
  
  // Performance
  accuracy        Float
  precision       Float
  recall          Float
  f1Score         Float
  
  // Features Used
  features        Json     // List of features and importance
  
  // Model Weights
  weights         Json     // Model coefficients
  
  // Status
  status          String   @default("active") // active, retraining, deprecated
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([modelType])
  @@index([status])
  @@map("predictive_models")
}
// ============================================================================
// LAYER 8: SEAMLESS CRM & TOOL INTEGRATIONS
// ============================================================================

model CrmConnection {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // CRM Provider
  provider        String   // salesforce, hubspot, dynamics, pipedrive, zoho, freshsales
  providerName    String   // Display name
  
  // Connection Status
  status          String   @default("disconnected") // connected, disconnected, error, syncing
  connectedAt     DateTime?
  lastSyncAt      DateTime?
  lastError       String?
  lastErrorAt     DateTime?
  
  // Authentication
  authType        String   // oauth2, api_key, username_password
  credentials     Json?    // Encrypted credentials
  accessToken     String?  // Encrypted
  refreshToken    String?  // Encrypted
  tokenExpiresAt  DateTime?
  
  // Connection Settings
  settings        Json     @default("{}")
  // {
  //   instanceUrl: "https://company.salesforce.com",
  //   apiVersion: "v58.0",
  //   sandbox: false,
  //   syncFrequency: "realtime", // realtime, hourly, daily
  //   conflictResolution: "crm_wins", // crm_wins, local_wins, newer_wins
  // }
  
  // Sync Configuration
  syncConfig      Json     @default("{}")
  // {
  //   contacts: { enabled: true, direction: "bidirectional" },
  //   companies: { enabled: true, direction: "bidirectional" },
  //   deals: { enabled: true, direction: "to_crm" },
  //   tasks: { enabled: true, direction: "bidirectional" },
  //   notes: { enabled: false, direction: "to_crm" }
  // }
  
  // Stats
  totalSynced     Int      @default(0)
  syncSuccessRate Float    @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  fieldMappings   CrmFieldMapping[]
  syncJobs        CrmSyncJob[]
  pipelineStages  CrmPipelineStage[]
  deals           CrmDeal[]
  tasks           CrmTask[]

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([status])
  @@map("crm_connections")
}

model CrmFieldMapping {
  id              String   @id @default(cuid())
  
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  
  // Entity Type
  entityType      String   // contact, company, deal, task
  
  // Field Mapping
  localField      String   // Our field name (e.g., "firstName")
  crmField        String   // CRM field name (e.g., "FirstName", "firstname")
  crmFieldId      String?  // CRM field API ID
  
  // Transformation
  transform       String?  // uppercase, lowercase, date_format, phone_format
  
  // Sync Direction
  direction       String   @default("bidirectional") // to_crm, from_crm, bidirectional
  
  // Required
  isRequired      Boolean  @default(false)
  
  // Active
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([connectionId, entityType, localField])
  @@index([connectionId])
  @@index([entityType])
  @@map("crm_field_mappings")
}

model CrmSyncJob {
  id              String   @id @default(cuid())
  
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  
  organizationId  String
  
  // Job Type
  jobType         String   // full_sync, incremental_sync, initial_import, push_to_crm
  entityType      String   // contact, company, deal, all
  
  // Status
  status          String   @default("pending") // pending, running, completed, failed, cancelled
  
  // Progress
  totalRecords    Int      @default(0)
  processedRecords Int     @default(0)
  successCount    Int      @default(0)
  errorCount      Int      @default(0)
  
  // Timing
  startedAt       DateTime?
  completedAt     DateTime?
  
  // Results
  errors          Json?    // Array of error details
  
  // Triggered By
  triggeredById   String?  // User ID
  isScheduled     Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
  @@map("crm_sync_jobs")
}

model CrmPipelineStage {
  id              String   @id @default(cuid())
  
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  
  organizationId  String
  
  // Stage Info
  name            String
  crmStageId      String   // CRM's stage ID
  displayOrder    Int
  
  // Probability
  winProbability  Int      @default(0) // 0-100
  
  // Category
  category        String   @default("open") // open, won, lost
  
  // Mapping
  localStageId    String?  // Our internal stage mapping
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([connectionId])
  @@index([crmStageId])
  @@map("crm_pipeline_stages")
}

model CrmDeal {
  id              String   @id @default(cuid())
  
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  
  organizationId  String
  
  // Deal Info
  crmDealId       String   // CRM's deal ID
  name            String
  value           Float?
  currency        String   @default("USD")
  
  // Stage
  stageId         String?
  pipelineStage   CrmPipelineStage? @relation(fields: [stageId], references: [id])
  
  // Related Records
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  
  // Dates
  closeDate       DateTime?
  expectedCloseDate DateTime?
  
  // Sync Status
  lastSyncedAt    DateTime @default(now())
  syncStatus      String   @default("synced") // synced, pending, conflict
  
  // Raw Data
  crmData         Json?    // Full CRM deal object
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([connectionId, crmDealId])
  @@index([organizationId])
  @@index([contactId])
  @@index([companyId])
  @@index([stageId])
  @@map("crm_deals")
}

model CrmTask {
  id              String   @id @default(cuid())
  
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  
  organizationId  String
  
  // Task Info
  crmTaskId       String   // CRM's task ID
  subject         String
  description     String?
  
  // Type
  taskType        String   @default("call") // call, email, meeting, todo, demo
  
  // Status
  status          String   @default("open") // open, completed, cancelled
  priority        String   @default("medium") // low, medium, high
  
  // Assignment
  assignedToId    String?  // User ID
  crmAssignedToId String?  // CRM user ID
  
  // Related Records
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  dealId          String?
  
  // Due Date
  dueDate         DateTime?
  completedAt     DateTime?
  
  // Reminder
  reminderSet     Boolean  @default(false)
  reminderTime    DateTime?
  
  // Sync Status
  lastSyncedAt    DateTime @default(now())
  syncStatus      String   @default("synced")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([connectionId, crmTaskId])
  @@index([organizationId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([dueDate])
  @@map("crm_tasks")
}

model WebhookSubscription {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Webhook Info
  name            String
  description     String?
  
  // Target
  url             String
  secret          String?  // For signature verification
  
  // Events
  events          String[] // contact.created, contact.updated, deal.won, etc.
  
  // Status
  isActive        Boolean  @default(true)
  
  // Retry Settings
  maxRetries      Int      @default(3)
  retryDelay      Int      @default(60) // seconds
  
  // Stats
  totalDelivered  Int      @default(0)
  totalFailed     Int      @default(0)
  lastDeliveredAt DateTime?
  lastFailedAt    DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  deliveries      WebhookDelivery[]

  @@index([organizationId])
  @@index([isActive])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  
