  _100m_500m
  _500m_1b
  _1b_plus
}

enum FundingStage {
  pre_seed
  seed
  series_a
  series_b
  series_c
  series_d_plus
  ipo
  acquired
  bootstrapped
  unknown
}

enum TechCategory {
  crm
  marketing_automation
  analytics
  ecommerce
  communication
  productivity
  infrastructure
