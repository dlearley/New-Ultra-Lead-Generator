  dev_tools
  design
  finance
  hr
  sales
  customer_support
  other
}

enum IntentType {
  website_visit
  content_download
  pricing_view
  demo_request
  trial_signup
  email_open
  email_click
  webinar_attendance
  funding_news
  technology_change
  hiring_activity
  social_engagement
  competitor_research
  comparison_view
}

enum IntentCategory {
  behavioral
  engagement
  firmographic
  technographic
  news
