  bouncedAt       DateTime?
  
  // Metadata
  openCount       Int      @default(0)
  clickCount      Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([enrollmentId])
  @@index([status])
  @@index([scheduledAt])
  @@map("step_executions")
}

model OutreachReply {
