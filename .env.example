# ==========================================
# Ultra Lead Generator - Environment Configuration
# ==========================================

# ------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------
DATABASE_URL=postgresql://ultra_user:ultra_pass@localhost:5433/ultra_leads?schema=public

# For Docker:
# DATABASE_URL=postgresql://ultra_user:ultra_pass@postgres:5432/ultra_leads?schema=public

# ------------------------------------------
# Redis (for queues and caching)
# ------------------------------------------
REDIS_URL=redis://localhost:6380

# For Docker:
# REDIS_URL=redis://redis:6379

# ------------------------------------------
# Authentication (JWT)
# ------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ------------------------------------------
# Encryption (for sensitive data)
# ------------------------------------------
# Generate a strong key: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-change-in-production

# ------------------------------------------
# API Configuration
# ------------------------------------------
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ------------------------------------------
# Data Enrichment Providers (Phase 2)
# ------------------------------------------

# Clearbit - Company and person enrichment
# Get API key: https://clearbit.com/
CLEARBIT_API_KEY=your-clearbit-api-key

# Hunter.io - Email verification and finder
# Get API key: https://hunter.io/
HUNTER_API_KEY=your-hunter-api-key

# BuiltWith - Technology detection
# Get API key: https://builtwith.com/
BUILTWITH_API_KEY=your-builtwith-api-key

# NewsAPI - Real-time company news
# Get API key: https://newsapi.org/
NEWSAPI_KEY=your-newsapi-key

# ------------------------------------------
# AI Providers (Optional - for production)
# ------------------------------------------
# OpenAI - For natural language processing
OPENAI_API_KEY=your-openai-api-key

# Anthropic - Alternative AI provider
ANTHROPIC_API_KEY=your-anthropic-api-key

# ------------------------------------------
# Monitoring (Optional)
# ------------------------------------------
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# ------------------------------------------
# Email Service (Optional)
# ------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ------------------------------------------
# Stripe (Optional - for billing)
# ------------------------------------------
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
