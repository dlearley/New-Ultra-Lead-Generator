  aiPrompt        String?  @db.Text
  
  // Category
  category        String   @default("general") // intro, follow_up, breakup, meeting_request
  
  // Usage Stats
  useCount        Int      @default(0)
  avgOpenRate     Float?
  avgReplyRate    Float?
  
  // Approval
  status          String   @default("active") // draft, active, archived
  approvedById    String?
  approvedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  steps           OutreachStep[]

  @@index([organizationId])
  @@index([channel])
  @@index([category])
  @@map("message_templates")
}

model SequenceEnrollment {
  id              String   @id @default(cuid())
  organizationId  String
  
  // Enrollment
  sequenceId      String
  sequence        OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // Assignment
  assignedToId    String?  // Sales rep
  
  // A/B Test Variant
  abVariant       String?  // "A" or "B"
  
  // Status
  status          String   @default("active") // active, paused, completed, exited
  
  // Current Position
  currentStepId   String?
  currentStepNumber Int    @default(0)
  
  // Timing
  enrolledAt      DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  lastStepAt      DateTime?
  nextStepAt      DateTime?
  
  // Exit Reason
  exitReason      String?  // replied, booked_meeting, opted_out, bounced
  
  // Performance
  totalOpens      Int      @default(0)
  totalClicks     Int      @default(0)
  totalReplies    Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  stepExecutions  StepExecution[]
  replies         OutreachReply[]

  @@unique([sequenceId, contactId])
  @@index([organizationId])
  @@index([contactId])
  @@index([status])
  @@index([nextStepAt])
  @@map("sequence_enrollments")
}

model StepExecution {
  id              String   @id @default(cuid())
