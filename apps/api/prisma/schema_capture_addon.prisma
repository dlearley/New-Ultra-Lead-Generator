// ============================================================================
// LEAD CAPTURE MODULE (Phase 1)
// ============================================================================

model LeadForm {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  // Form Configuration
  formType        String   @default("inline")
  status          String   @default("draft")
  
  // Design & Template
  design          Json     @default("{}")
  template        String?
  
  // Form Fields
  fields          Json     @default("[]")
  
  // Display Behavior
  triggerConfig   Json     @default("{}")
  displayRules    Json     @default("{}")
  
  // Post-Submission
  thankYouMessage String?
  redirectUrl     String?
  sendEmailConfirmation Boolean @default(false)
  
  // Lead magnet
  leadMagnetId    String?
  leadMagnet      LeadMagnet? @relation(fields: [leadMagnetId], references: [id])
  
  // Tracking
  views           Int      @default(0)
  submissions     Int      @default(0)
  conversions     Int      @default(0)
  conversionRate  Float    @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  formSubmissions FormSubmission[]
  conversions     Conversion[]

  @@index([organizationId])
  @@index([status])
  @@map("lead_forms")
}

model FormSubmission {
  id          String   @id @default(cuid())
  formId      String
  form        LeadForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  organizationId String
  data        Json     @default("{}")
  
  visitorId   String?
  visitor     WebsiteVisitor? @relation(fields: [visitorId], references: [id])
  
  ipAddress   String?
  userAgent   String?
  referrer    String?
  pageUrl     String?
  
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  
  contactId   String?
  converted   Boolean  @default(false)
  
  verified    Boolean  @default(false)
  verifiedAt  DateTime?
  
  submittedAt DateTime @default(now())

  @@index([formId])
  @@index([visitorId])
  @@index([organizationId])
  @@index([submittedAt])
  @@map("form_submissions")
}

model LandingPage {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  slug            String   @unique
  title           String
  description     String?
  content         Json     @default("[]")
  template        String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  status          String   @default("draft")
  publishedAt     DateTime?
  views           Int      @default(0)
  uniqueViews     Int      @default(0)
  conversions     Int      @default(0)
  conversionRate  Float    @default(0)
  formId          String?
  form            LeadForm? @relation(fields: [formId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([slug])
  @@map("landing_pages")
}

model WebsiteVisitor {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fingerprint     String
  sessionId       String
  ipAddress       String?
  country         String?
  city            String?
  region          String?
  timezone        String?
  companyName     String?
  companyDomain   String?
  companyIndustry String?
  companySize     String?
  companyRevenue  String?
  pageViews       Int      @default(0)
  sessionCount    Int      @default(1)
  firstVisitAt    DateTime @default(now())
  lastVisitAt     DateTime @updatedAt
  leadScore       Int      @default(0)
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])
  identifiedAt    DateTime?
  pageViewsList   VisitorPageView[]
  formSubmissions FormSubmission[]

  @@unique([organizationId, fingerprint])
  @@index([organizationId])
  @@index([fingerprint])
  @@index([contactId])
  @@index([companyDomain])
  @@map("website_visitors")
}

model VisitorPageView {
  id          String   @id @default(cuid())
  visitorId   String
  visitor     WebsiteVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  pageUrl     String
  pageTitle   String?
  referrer    String?
  timeOnPage  Int?
  scrollDepth Int?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  viewedAt    DateTime @default(now())

  @@index([visitorId])
  @@index([viewedAt])
  @@map("visitor_page_views")
}

model Chatbot {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  avatarUrl       String?
  primaryColor    String   @default("#3b82f6")
  position        String   @default("bottom-right")
  welcomeMessage  String   @default("Hi! How can I help you today?")
  welcomeDelay    Int      @default(2)
  flows           Json     @default("[]")
  autoOpen        Boolean  @default(false)
  autoOpenDelay   Int      @default(10)
  showOnMobile    Boolean  @default(true)
  workingHours    Json?
  status          String   @default("active")
  conversations   Int      @default(0)
  leadsCaptured   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("chatbots")
}

model LeadMagnet {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  type            String
  fileUrl         String?
  fileSize        Int?
  content         String?
  externalUrl     String?
  deliveryMethod  String   @default("immediate")
  emailTemplate   String?
  requireEmail    Boolean  @default(true)
  requirePhone    Boolean  @default(false)
  views           Int      @default(0)
  downloads       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  forms           LeadForm[]

  @@index([organizationId])
  @@index([type])
  @@map("lead_magnets")
}

model Conversion {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceType      String
  sourceId        String?
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])
  submissionId    String?
  submission      FormSubmission? @relation(fields: [submissionId], references: [id])
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  referrer        String?
  landingPage     String?
  visitorId       String?
  pageViews       Int      @default(0)
  timeToConvert   Int?
  estimatedValue  Float?
  convertedAt     DateTime @default(now())

  @@index([organizationId])
  @@index([contactId])
  @@index([sourceType])
  @@index([convertedAt])
  @@map("conversions")
}
