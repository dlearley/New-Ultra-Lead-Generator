  ipo
  product_launch
  partnership
  executive_change
  expansion
  layoffs
  awards
  legal
  other
}

enum Sentiment {
  very_positive
  positive
  neutral
  negative
  very_negative
}

enum ActivityType {
  email_sent
  email_opened
  email_clicked
  call_made
  meeting_scheduled
  meeting_completed
  note_added
  task_created
  task_completed
  deal_created
  deal_won
  deal_lost
  imported
  exported
  enriched
  viewed
}

enum ListType {
  static
  dynamic
  smart
}

enum EnrichmentStatus {
  pending
  processing
  completed
  failed
  skipped
}

enum CreditType {
  contact
  company
  email_verification
  phone_verification
  intent_signal
}

enum CrmType {
  salesforce
  hubspot
  pipedrive
  zoho
  freshsales
  close
  other
}

enum FieldType {
  string
  number
  boolean
  date
  datetime
  email
  phone
  url
  select
  multiselect
  text
}

enum SyncStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum BuyingStage {
  unknown
  awareness
  consideration
  decision
  purchase
  churned
}

// ============================================================================
// BULK IMPORT
// ============================================================================

model BulkImportJob {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // File info
  fileName        String
  fileSize        Int
  
  // Status
  status          ImportJobStatus @default(pending)
  
  // Progress
  totalRows       Int @default(0)
  processedRows   Int @default(0)
  validRows       Int @default(0)
  invalidRows     Int @default(0)
  createdRecords  Int @default(0)
  updatedRecords  Int @default(0)
  skippedRows     Int @default(0)
  
  // Configuration
  config          Json
  
  // Errors
  errors          Json @default("[]")
  
  // Timestamps
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("bulk_import_jobs")
}

enum ImportJobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

// Legacy model - keeping for backwards compatibility
model BusinessLead {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  email          String
  firstName      String?
  lastName       String?
  phone          String?
  company        String?
  jobTitle       String?
  source         String?
  status         LeadStatus    @default(NEW)
  customFields   Json?
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  syncJobs       SyncJob[]

  @@unique([organizationId, email])
  @@map("business_leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}
