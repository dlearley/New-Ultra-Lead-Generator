  subject         String?
  body            String?  @db.Text
  
  // Timing
  scheduledAt     DateTime
  sentAt          DateTime?
  
  // Delivery
  messageId       String?  // Provider message ID
  
  // Tracking
  openedAt        DateTime?
  clickedAt       DateTime?
